{
  "status": "READY_FOR_REAL_WORLD_TEST",
  "version": "1.0",
  "test_duration_days": 14,
  "test_goal": "Validate market demand for Python Quest before building platform",

  "signal_levels": {
    "strong": {
      "description": "Clear market demand, proceed with confidence",
      "decision": "GO",
      "metrics": {
        "landing_page_views": {
          "min": 300,
          "description": "Unique page views across 14 days"
        },
        "email_signups": {
          "min": 30,
          "description": "Total email captures from landing"
        },
        "email_capture_rate": {
          "min_percent": 15,
          "description": "Signups / views * 100"
        },
        "demo_completion_reported": {
          "min": 10,
          "description": "Self-reported completion of 3 demo lessons"
        },
        "would_pay_at_39_eur": {
          "min_percent": 30,
          "description": "Survey respondents selecting 'yes' or 'probably'"
        },
        "price_inquiries": {
          "min": 3,
          "description": "Organic questions about pricing"
        },
        "community_engagement": {
          "min_meaningful_comments": 20,
          "description": "Thoughtful comments across all posts"
        }
      }
    },

    "soft": {
      "description": "Some traction but needs refinement",
      "decision": "SOFT_GO",
      "metrics": {
        "landing_page_views": {
          "min": 100,
          "max": 299,
          "description": "Some interest but limited reach"
        },
        "email_signups": {
          "min": 10,
          "max": 29,
          "description": "Core interest exists"
        },
        "email_capture_rate": {
          "min_percent": 8,
          "max_percent": 14,
          "description": "Moderate conversion, room for improvement"
        },
        "demo_completion_reported": {
          "min": 5,
          "max": 9,
          "description": "Some engagement with content"
        },
        "would_pay_at_39_eur": {
          "min_percent": 15,
          "max_percent": 29,
          "description": "Price sensitivity or value perception issues"
        },
        "price_inquiries": {
          "min": 1,
          "max": 2,
          "description": "Limited buying intent signals"
        },
        "community_engagement": {
          "min_meaningful_comments": 10,
          "max": 19,
          "description": "Some community interest"
        }
      }
    },

    "pivot": {
      "description": "Weak signals but something to work with",
      "decision": "PIVOT",
      "metrics": {
        "landing_page_views": {
          "min": 50,
          "max": 99,
          "description": "Limited interest, targeting or positioning issue"
        },
        "email_signups": {
          "min": 5,
          "max": 9,
          "description": "Core audience unclear"
        },
        "email_capture_rate": {
          "min_percent": 5,
          "max_percent": 7,
          "description": "Landing or offer needs major work"
        },
        "demo_completion_reported": {
          "min": 2,
          "max": 4,
          "description": "Content may not engage"
        },
        "would_pay_at_39_eur": {
          "min_percent": 5,
          "max_percent": 14,
          "description": "Value proposition unclear"
        },
        "price_inquiries": {
          "min": 0,
          "max": 0,
          "description": "No buying intent"
        },
        "community_engagement": {
          "min_meaningful_comments": 5,
          "max": 9,
          "description": "Limited community response"
        }
      }
    },

    "no_go": {
      "description": "No market signal",
      "decision": "NO_GO",
      "metrics": {
        "landing_page_views": {
          "max": 49,
          "description": "No interest in concept"
        },
        "email_signups": {
          "max": 4,
          "description": "Value proposition not resonating"
        },
        "email_capture_rate": {
          "max_percent": 4,
          "description": "Severe landing or offer issues"
        },
        "demo_completion_reported": {
          "max": 1,
          "description": "Content doesn't engage"
        },
        "would_pay_at_39_eur": {
          "max_percent": 4,
          "description": "No willingness to pay"
        },
        "price_inquiries": {
          "max": 0,
          "description": "No commercial interest"
        },
        "community_engagement": {
          "max_meaningful_comments": 4,
          "description": "Community rejection or indifference"
        }
      }
    }
  },

