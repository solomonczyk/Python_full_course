  "offer_performance_criteria": {
    "offer_1_gaming": {
      "expected_best_segment": "teenagers_parents",
      "success_rate_threshold": 15,
      "pivot_trigger": "too_childish_feedback_over_30_percent"
    },
    "offer_2_dropped": {
      "expected_best_segment": "dropped_before",
      "success_rate_threshold": 12,
      "pivot_trigger": "negative_tone_feedback_over_20_percent"
    },
    "offer_3_adult": {
      "expected_best_segment": "adult_beginners_ai",
      "success_rate_threshold": 12,
      "pivot_trigger": "not_serious_enough_feedback_over_25_percent"
    }
  },

  "pricing_validation": {
    "test_prices": [19, 29, 39, 49],
    "acceptable_range": {
      "min": 19,
      "max": 49,
      "target": 39
    },
    "signals": {
      "strong": "40%+ willing at €39",
      "acceptable": "25-40% willing at €39",
      "concerning": "15-25% willing at €39",
      "critical": "< 15% willing at €39"
    }
  },

  "decision_framework": {
    "go": {
