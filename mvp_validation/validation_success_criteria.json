  "segment_validation_criteria": {
    "teenagers": {
      "minimum_engagement_signals": 5,
      "validation_indicators": [
        "Sharing with friends",
        "Questions about characters",
        "Excitement about final game",
        "Completing all 3 demo lessons"
      ]
    },
    "parents": {
      "minimum_engagement_signals": 3,
      "validation_indicators": [
        "Price inquiries",
        "Questions about educational value",
        "Concerns about age appropriateness",
        "Asking about sibling/friend deals"
      ]
    },
    "adult_beginners": {
      "minimum_engagement_signals": 5,
      "validation_indicators": [
        "Questions about curriculum depth",
        "Time commitment questions",
        "Career relevance questions",
        "Comparison to other courses"
      ]
    },
    "dropped_before": {
      "minimum_engagement_signals": 3,
      "validation_indicators": [
        "Sharing past struggles",
        "This is what I needed responses",
        "Completing all demos",
        "Emotional engagement"
      ]
    }
