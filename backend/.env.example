# Backend environment variables
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# Local development (leave empty to use SQLite)
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=

# Optional: CORS allowed origin (e.g., your production domain)
ALLOWED_ORIGIN=https://python-full-course.vercel.app
